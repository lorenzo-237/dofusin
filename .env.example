# "mock" (défaut) = données fictives en mémoire/localStorage, aucun réseau requis.
# "http" = vraies requêtes vers l'API REST Express décrite dans project/cahier_charges.md.
VITE_API_STRATEGY=mock

# Utilisé uniquement quand VITE_API_STRATEGY=http.
VITE_API_BASE_URL=http://localhost:3000/api

# Client ID Discord (public, safe à embarquer côté frontend — voir
# dofusin-api/CLAUDE.md pour le CLIENT_SECRET, qui lui reste côté serveur).
# Doit matcher DISCORD_CLIENT_ID dans dofusin-api/.env. Utilisé uniquement
# quand VITE_API_STRATEGY=http *et* dans le shell Tauri (sinon le bouton
# Discord crée directement une session factice, voir docs/discord-auth-deep-link.md).
VITE_DISCORD_CLIENT_ID=
